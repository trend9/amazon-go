rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to verify if the authenticated user is the designated admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'mattan029@gmail.com';
    }

    // Articles catalog is readable by any public visitor, but writable only by the admin or cron job using secret token
    match /articles/{articleId} {
      allow read: if true;
      allow write, delete: if isAdmin() || (request.resource.data != null && request.resource.data.cronSecret == 'mattan029-cron-bypass');
    }

    // Config parameters are readable by anyone, only writable by the admin
    match /settings/config {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // Stock products collection for cron replenishment (needs unauthenticated read/write)
    match /stock_products/{prodId} {
      allow read, write: if true;
    }

    // System logs collection for shared administration console synchronization
    match /system_logs/{logId} {
      allow read, write: if true;
    }
  }
}
